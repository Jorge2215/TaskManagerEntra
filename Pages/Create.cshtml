@page
@model TaskManager.Pages.CreateModel

<h2>Crear Nueva Tarea</h2>

<form method="post">
    <div class="form-group">
        <label for="Title">Título</label>
        <input asp-for="Task.Title" class="form-control" />
        <span asp-validation-for="Task.Title" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="IsCompleted">Completada</label>
        <input asp-for="Task.IsCompleted" type="checkbox" />
    </div>

    <button type="submit" class="btn btn-primary">Guardar</button>
</form>
