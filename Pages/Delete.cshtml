@page "{id:int}"
@model TaskManager.Pages.DeleteModel

<h2>Eliminar Tarea</h2>

<div>
    <h4>¿Estás seguro de que querés eliminar esta tarea?</h4>
    <dl class="row">
        <dt class="col-sm-2">Título</dt>
        <dd class="col-sm-10">@Model.Task.Title</dd>

        <dt class="col-sm-2">Completada</dt>
        <dd class="col-sm-10">@Model.Task.IsCompleted</dd>

        <dt class="col-sm-2">Creada</dt>
        <dd class="col-sm-10">@Model.Task.CreatedAt.ToString("g")</dd>
    </dl>
</div>

<form method="post">
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>
